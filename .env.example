# Kraken API — live trading only. Create Order permission only, NO withdrawal permission.
# Never put real keys here. This file IS committed. .env is NOT.
KRAKEN_API_KEY=your_api_key_here
KRAKEN_API_SECRET=your_api_secret_here

# Database — SQLAlchemy URL used by backtester and live engine
# On Mac (dev):        postgresql+psycopg2://user:password@localhost/forge_anchor
DATABASE_URL=postgresql+psycopg2://your_db_user:your_db_password@localhost/forge_anchor

# Supabase connection string — used by GitHub Actions workflows (executor + market_data_updater)
# IMPORTANT: Use the Session Pooler URL (not Direct Connection) — direct uses IPv6 which
# GitHub Actions runners don't support. Get from: Supabase → Settings → Database → Session pooler
SUPABASE_DATABASE_URL=postgresql://postgres.your-project-ref:your_supabase_password@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# Database — individual vars used by src/data/downloader.py
DB_HOST=localhost
DB_PORT=5432
DB_NAME=forge_anchor
DB_USER=your_db_user
DB_PASSWORD=your_db_password
